{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Simulate ALU",
            "type": "shell",
            "command": "make sim-alu",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Simulate Register File",
            "type": "shell",
            "command": "make sim-regfile",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Simulate CPU",
            "type": "shell",
            "command": "make sim-cpu",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "View ALU Waveform",
            "type": "shell",
            "command": "gtkwave alu_tb.vcd &",
            "group": "none",
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": []
        },
        {
            "label": "View CPU Waveform",
            "type": "shell",
            "command": "gtkwave cpu_tb.vcd &",
            "group": "none",
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": []
        },
        {
            "label": "Synthesize CPU",
            "type": "shell",
            "command": "make synth",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Clean Project",
            "type": "shell",
            "command": "make clean",
            "group": "none",
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": []
        },
        {
            "label": "Check Verilog Syntax (Current File)",
            "type": "shell",
            "command": "iverilog -t null -Wall ${file}",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": {
                "owner": "iverilog",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^(.*):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "severity": 3,
                    "message": 4
                }
            }
        }
    ]
}
