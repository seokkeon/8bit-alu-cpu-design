# synth.ys - Yosys synthesis script for CPU

# Read design files
read_verilog rtl/alu.v
read_verilog rtl/regfile.v
read_verilog rtl/cpu.v

# Synthesize to generic gate library
synth -top cpu

# Map to cells
dfflibmap -liberty synth/cells.lib
abc -liberty synth/cells.lib

# Clean up
clean

# Generate statistics
stat

# Write synthesized netlist
write_verilog synth/cpu_synth.v

# Write graphical representation
show -prefix synth/cpu_diagram -format dot
